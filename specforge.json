{
  "$schema": "https://specforge.dev/schema/specforge.json",
  "name": "specforge",
  "version": "1.0",
  "spec_root": "./spec",
  "strict": false,
  "plugins": [
    "@specforge/product",
    "@specforge/governance"
  ],
  "providers": {
    "gh": {
      "package": "@specforge/gh",
      "repo": "anthropics/specforge",
      "kinds": ["issue", "pr"]
    }
  },
  "personas": {
    "developer": "Specification Author",
    "architect": "System Architect",
    "ci": "CI Pipeline",
    "contributor": "Open Source Contributor"
  },
  "surfaces": {
    "cli": "Command Line Interface",
    "ide": "IDE with LSP",
    "ci_surface": "CI/CD Pipeline"
  },
  "test_dirs": ["tests/"],
  "coverage": {
    "threshold": 90,
    "require_violation_tests": true,
    "fail_on_unknown_ids": true
  },
  "gen": {
    "typescript": {
      "out": "packages/generated/",
      "result": "hex-di",
      "readonly": true,
      "naming": "camelCase",
      "tests": "@specforge/vitest"
    },
    "rust": {
      "out": "src/generated/",
      "test_out": "tests/spec/",
      "result": "thiserror",
      "naming": "snake_case",
      "tests": "@specforge/rust"
    }
  }
}
