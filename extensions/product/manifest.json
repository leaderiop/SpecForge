{
  "name": "@specforge/product",
  "version": "1.0.0",
  "manifestVersion": 2,
  "wasmPath": "product.wasm",
  "extShort": "product",
  "queryScope": "product",
  "contributes": {
    "entities": true,
    "validators": true
  },
  "verifyKinds": ["acceptance"],
  "incremental": true,
  "fields": [
    { "name": "tags", "fieldType": "string_list" }
  ],
  "entityKinds": [
    {
      "name": "Feature",
      "keyword": "feature",
      "testable": false,
      "supportsVerify": true,
      "allowedVerifyKinds": ["acceptance"],
      "semanticToken": "class",
      "lspIcon": "Class",
      "dotShape": "box",
      "dotColor": "#2196F3",
      "dotFillcolor": "#E3F2FD",
      "fields": [
        { "name": "description", "fieldType": "string" },
        { "name": "problem", "fieldType": "string" },
        { "name": "solution", "fieldType": "string" },
        { "name": "priority", "fieldType": "string" },
        { "name": "status", "fieldType": "string" },
        { "name": "acceptance", "fieldType": "string_list" },
        { "name": "depends_on", "fieldType": "reference_list", "edge": "FeatureDependsOn", "targetKind": "feature" },
        { "name": "features", "fieldType": "reference_list", "targetKind": "feature" },
        { "name": "behaviors", "fieldType": "reference_list", "targetKind": "behavior" },
        { "name": "refs", "fieldType": "string_list" },
        { "name": "reason", "fieldType": "string" },
        { "name": "owner", "fieldType": "string" },
        { "name": "contributors", "fieldType": "string_list" },
        { "name": "effort", "fieldType": "string" }
      ]
    },
    {
      "name": "Journey",
      "keyword": "journey",
      "testable": false,
      "supportsVerify": false,
      "semanticToken": "event",
      "lspIcon": "Event",
      "dotShape": "ellipse",
      "dotColor": "#FF9800",
      "dotFillcolor": "#FFF3E0",
      "fields": [
        { "name": "persona", "fieldType": "reference", "edge": "JourneyPersona", "targetKind": "persona" },
        { "name": "description", "fieldType": "string" },
        { "name": "channels", "fieldType": "reference_list", "edge": "JourneyChannel", "targetKind": "channel" },
        { "name": "features", "fieldType": "reference_list", "edge": "JourneyFeature", "targetKind": "feature" },
        { "name": "flow", "fieldType": "string_list" },
        { "name": "priority", "fieldType": "string" }
      ]
    },
    {
      "name": "Deliverable",
      "keyword": "deliverable",
      "testable": false,
      "supportsVerify": true,
      "allowedVerifyKinds": ["acceptance"],
      "semanticToken": "struct",
      "lspIcon": "Package",
      "dotShape": "box3d",
      "dotColor": "#4CAF50",
      "dotFillcolor": "#E8F5E9",
      "fields": [
        { "name": "description", "fieldType": "string" },
        { "name": "artifact_type", "fieldType": "string" },
        { "name": "status", "fieldType": "string" },
        { "name": "journeys", "fieldType": "reference_list", "edge": "DeliverableJourney", "targetKind": "journey" },
        { "name": "modules", "fieldType": "reference_list", "edge": "DeliverableModule", "targetKind": "module" },
        { "name": "version", "fieldType": "string" },
        { "name": "milestones", "fieldType": "reference_list", "edge": "DeliverableMilestone", "targetKind": "milestone" },
        { "name": "depends_on", "fieldType": "reference_list", "edge": "DeliverableDependsOn", "targetKind": "deliverable" },
        { "name": "reason", "fieldType": "string" },
        { "name": "owner", "fieldType": "string" },
        { "name": "contributors", "fieldType": "string_list" }
      ]
    },
    {
      "name": "Milestone",
      "keyword": "milestone",
      "testable": false,
      "supportsVerify": true,
      "allowedVerifyKinds": ["acceptance"],
      "semanticToken": "namespace",
      "lspIcon": "Folder",
      "dotShape": "hexagon",
      "dotColor": "#9C27B0",
      "dotFillcolor": "#F3E5F5",
      "fields": [
        { "name": "description", "fieldType": "string" },
        { "name": "status", "fieldType": "string" },
        { "name": "features", "fieldType": "reference_list", "edge": "MilestoneFeature", "targetKind": "feature" },
        { "name": "exit_criteria", "fieldType": "string_list" },
        { "name": "target_date", "fieldType": "string" },
        { "name": "start_date", "fieldType": "string" },
        { "name": "modules", "fieldType": "reference_list", "edge": "MilestoneModule", "targetKind": "module" },
        { "name": "depends_on", "fieldType": "reference_list", "edge": "MilestoneDependsOn", "targetKind": "milestone" },
        { "name": "blockers", "fieldType": "string_list" },
        { "name": "priority", "fieldType": "string" },
        { "name": "reason", "fieldType": "string" },
        { "name": "owner", "fieldType": "string" },
        { "name": "contributors", "fieldType": "string_list" },
        { "name": "refs", "fieldType": "string_list" }
      ]
    },
    {
      "name": "Module",
      "keyword": "module",
      "testable": false,
      "supportsVerify": false,
      "semanticToken": "namespace",
      "lspIcon": "Module",
      "dotShape": "component",
      "dotColor": "#607D8B",
      "dotFillcolor": "#ECEFF1",
      "fields": [
        { "name": "family", "fieldType": "string" },
        { "name": "description", "fieldType": "string" },
        { "name": "features", "fieldType": "reference_list", "edge": "ModuleFeature", "targetKind": "feature" },
        { "name": "depends_on", "fieldType": "reference_list", "edge": "ModuleDependsOn", "targetKind": "module" },
        { "name": "reason", "fieldType": "string" }
      ]
    },
    {
      "name": "Term",
      "keyword": "term",
      "testable": false,
      "supportsVerify": false,
      "singleton": false,
      "semanticToken": "string",
      "lspIcon": "Text",
      "dotShape": "note",
      "dotColor": "#795548",
      "dotFillcolor": "#EFEBE9",
      "fields": [
        { "name": "definition", "fieldType": "string", "required": true },
        { "name": "context", "fieldType": "string" },
        { "name": "aliases", "fieldType": "string_list" },
        { "name": "see_also", "fieldType": "reference_list", "edge": "TermSeeAlso", "targetKind": "term" }
      ]
    },
    {
      "name": "Persona",
      "keyword": "persona",
      "testable": false,
      "supportsVerify": false,
      "semanticToken": "variable",
      "lspIcon": "Variable",
      "dotShape": "ellipse",
      "dotColor": "#E91E63",
      "dotFillcolor": "#FCE4EC",
      "fields": [
        { "name": "description", "fieldType": "string" },
        { "name": "technical_level", "fieldType": "string" },
        { "name": "goals", "fieldType": "string_list" },
        { "name": "pain_points", "fieldType": "string_list" },
        { "name": "status", "fieldType": "string" },
        { "name": "reason", "fieldType": "string" }
      ]
    },
    {
      "name": "Channel",
      "keyword": "channel",
      "testable": false,
      "supportsVerify": false,
      "semanticToken": "interface",
      "lspIcon": "Interface",
      "dotShape": "rectangle",
      "dotColor": "#00BCD4",
      "dotFillcolor": "#E0F7FA",
      "fields": [
        { "name": "description", "fieldType": "string" },
        { "name": "interaction_model", "fieldType": "string" },
        { "name": "url", "fieldType": "string" },
        { "name": "status", "fieldType": "string" },
        { "name": "reason", "fieldType": "string" }
      ]
    },
    {
      "name": "Release",
      "keyword": "release",
      "testable": false,
      "supportsVerify": false,
      "semanticToken": "constant",
      "lspIcon": "Constant",
      "dotShape": "doubleoctagon",
      "dotColor": "#FF5722",
      "dotFillcolor": "#FBE9E7",
      "fields": [
        { "name": "description", "fieldType": "string" },
        { "name": "version", "fieldType": "string", "required": true },
        { "name": "status", "fieldType": "string" },
        { "name": "deliverables", "fieldType": "reference_list", "edge": "ReleaseDeliverable", "targetKind": "deliverable" },
        { "name": "milestones", "fieldType": "reference_list", "edge": "ReleaseMilestone", "targetKind": "milestone" },
        { "name": "target_date", "fieldType": "string" },
        { "name": "release_date", "fieldType": "string" },
        { "name": "changelog", "fieldType": "string" },
        { "name": "depends_on", "fieldType": "reference_list", "edge": "ReleaseDependsOn", "targetKind": "release" },
        { "name": "owner", "fieldType": "string" },
        { "name": "contributors", "fieldType": "string_list" },
        { "name": "reason", "fieldType": "string" },
        { "name": "refs", "fieldType": "string_list" }
      ]
    },
    {
      "name": "Capability",
      "keyword": "capability",
      "testable": false,
      "supportsVerify": false,
      "semanticToken": "function",
      "lspIcon": "Method",
      "dotShape": "component",
      "dotColor": "#00BCD4",
      "dotFillcolor": "#E0F7FA",
      "fields": [
        { "name": "persona", "fieldType": "string" },
        { "name": "surface", "fieldType": "reference_list" },
        { "name": "features", "fieldType": "reference_list", "targetKind": "feature" },
        { "name": "flow", "fieldType": "string" },
        { "name": "description", "fieldType": "string" }
      ]
    },
    {
      "name": "Library",
      "keyword": "library",
      "testable": false,
      "supportsVerify": false,
      "semanticToken": "module",
      "lspIcon": "Package",
      "dotShape": "folder",
      "dotColor": "#795548",
      "dotFillcolor": "#EFEBE9",
      "fields": [
        { "name": "family", "fieldType": "string" },
        { "name": "features", "fieldType": "reference_list", "targetKind": "feature" },
        { "name": "depends_on", "fieldType": "reference_list", "targetKind": "library" },
        { "name": "ports_defined", "fieldType": "reference_list", "targetKind": "port" },
        { "name": "ports_consumed", "fieldType": "reference_list", "targetKind": "port" },
        { "name": "description", "fieldType": "string" }
      ]
    },
    {
      "name": "Roadmap",
      "keyword": "roadmap",
      "testable": false,
      "supportsVerify": false,
      "semanticToken": "namespace",
      "lspIcon": "Folder",
      "dotShape": "tab",
      "dotColor": "#3F51B5",
      "dotFillcolor": "#E8EAF6",
      "fields": [
        { "name": "status", "fieldType": "string" },
        { "name": "behaviors", "fieldType": "reference_list", "targetKind": "behavior" },
        { "name": "features", "fieldType": "reference_list", "targetKind": "feature" },
        { "name": "libraries", "fieldType": "reference_list", "targetKind": "library" },
        { "name": "criteria", "fieldType": "string_list" },
        { "name": "depends_on", "fieldType": "reference_list", "targetKind": "roadmap" },
        { "name": "description", "fieldType": "string" }
      ]
    }
  ],
  "edgeTypes": [
    { "label": "FeatureDependsOn", "sourceKind": "feature", "targetKind": "feature", "edgeStyle": "dashed", "edgeColor": "#2196F3" },
    { "label": "JourneyFeature", "sourceKind": "journey", "targetKind": "feature", "edgeStyle": "solid", "edgeColor": "#FF9800" },
    { "label": "JourneyPersona", "sourceKind": "journey", "targetKind": "persona", "edgeStyle": "solid", "edgeColor": "#E91E63" },
    { "label": "JourneyChannel", "sourceKind": "journey", "targetKind": "channel", "edgeStyle": "solid", "edgeColor": "#00BCD4" },
    { "label": "DeliverableJourney", "sourceKind": "deliverable", "targetKind": "journey", "edgeStyle": "solid", "edgeColor": "#4CAF50" },
    { "label": "DeliverableModule", "sourceKind": "deliverable", "targetKind": "module", "edgeStyle": "solid", "edgeColor": "#607D8B" },
    { "label": "DeliverableMilestone", "sourceKind": "deliverable", "targetKind": "milestone", "edgeStyle": "solid", "edgeColor": "#9C27B0" },
    { "label": "DeliverableDependsOn", "sourceKind": "deliverable", "targetKind": "deliverable", "edgeStyle": "dashed", "edgeColor": "#4CAF50" },
    { "label": "MilestoneFeature", "sourceKind": "milestone", "targetKind": "feature", "edgeStyle": "solid", "edgeColor": "#9C27B0" },
    { "label": "MilestoneModule", "sourceKind": "milestone", "targetKind": "module", "edgeStyle": "solid", "edgeColor": "#607D8B" },
    { "label": "MilestoneDependsOn", "sourceKind": "milestone", "targetKind": "milestone", "edgeStyle": "dashed", "edgeColor": "#9C27B0" },
    { "label": "ModuleFeature", "sourceKind": "module", "targetKind": "feature", "edgeStyle": "solid", "edgeColor": "#607D8B" },
    { "label": "ModuleDependsOn", "sourceKind": "module", "targetKind": "module", "edgeStyle": "dashed", "edgeColor": "#607D8B" },
    { "label": "TermSeeAlso", "sourceKind": "term", "targetKind": "term", "edgeStyle": "dotted", "edgeColor": "#795548" },
    { "label": "ReleaseDeliverable", "sourceKind": "release", "targetKind": "deliverable", "edgeStyle": "solid", "edgeColor": "#FF5722" },
    { "label": "ReleaseMilestone", "sourceKind": "release", "targetKind": "milestone", "edgeStyle": "solid", "edgeColor": "#FF5722" },
    { "label": "ReleaseDependsOn", "sourceKind": "release", "targetKind": "release", "edgeStyle": "dashed", "edgeColor": "#FF5722" }
  ],
  "validationRules": [
    {
      "code": "W077",
      "severity": "warning",
      "messageTemplate": "feature '{id}' has invalid status '{value}' — expected one of: proposed, accepted, in_progress, done, deferred, deprecated",
      "check": "field_value_constraint",
      "targetKind": "feature",
      "field": "status",
      "constraint": { "kind": "one_of", "values": ["proposed", "accepted", "in_progress", "done", "deferred", "deprecated"] }
    },
    {
      "code": "W078",
      "severity": "warning",
      "messageTemplate": "{kind} '{id}' has invalid priority '{value}' — expected one of: critical, high, medium, low",
      "check": "field_value_constraint",
      "targetKind": "feature",
      "field": "priority",
      "constraint": { "kind": "one_of", "values": ["critical", "high", "medium", "low"] }
    },
    {
      "code": "W078",
      "severity": "warning",
      "messageTemplate": "{kind} '{id}' has invalid priority '{value}' — expected one of: critical, high, medium, low",
      "check": "field_value_constraint",
      "targetKind": "journey",
      "field": "priority",
      "constraint": { "kind": "one_of", "values": ["critical", "high", "medium", "low"] }
    },
    {
      "code": "W078",
      "severity": "warning",
      "messageTemplate": "{kind} '{id}' has invalid priority '{value}' — expected one of: critical, high, medium, low",
      "check": "field_value_constraint",
      "targetKind": "milestone",
      "field": "priority",
      "constraint": { "kind": "one_of", "values": ["critical", "high", "medium", "low"] }
    },
    {
      "code": "W078",
      "severity": "warning",
      "messageTemplate": "{kind} '{id}' has invalid priority '{value}' — expected one of: critical, high, medium, low",
      "check": "field_value_constraint",
      "targetKind": "constraint",
      "field": "priority",
      "constraint": { "kind": "one_of", "values": ["critical", "high", "medium", "low"] }
    },
    {
      "code": "W079",
      "severity": "warning",
      "messageTemplate": "milestone '{id}' has invalid status '{value}' — expected one of: planned, in_progress, completed, blocked",
      "check": "field_value_constraint",
      "targetKind": "milestone",
      "field": "status",
      "constraint": { "kind": "one_of", "values": ["planned", "in_progress", "completed", "blocked"] }
    },
    {
      "code": "W080",
      "severity": "warning",
      "messageTemplate": "deliverable '{id}' has invalid artifact_type '{value}' — expected one of: cli, service, library, web_app, mobile_app, api, extension, documentation, package",
      "check": "field_value_constraint",
      "targetKind": "deliverable",
      "field": "artifact_type",
      "constraint": { "kind": "one_of", "values": ["cli", "service", "library", "web_app", "mobile_app", "api", "extension", "documentation", "package"] }
    },
    {
      "code": "W083",
      "severity": "warning",
      "messageTemplate": "persona '{id}' has invalid status '{value}' — expected one of: active, deprecated",
      "check": "field_value_constraint",
      "targetKind": "persona",
      "field": "status",
      "constraint": { "kind": "one_of", "values": ["active", "deprecated"] }
    },
    {
      "code": "W084",
      "severity": "warning",
      "messageTemplate": "channel '{id}' has invalid status '{value}' — expected one of: active, deprecated",
      "check": "field_value_constraint",
      "targetKind": "channel",
      "field": "status",
      "constraint": { "kind": "one_of", "values": ["active", "deprecated"] }
    },
    {
      "code": "W085",
      "severity": "warning",
      "messageTemplate": "deliverable '{id}' has invalid status '{value}' — expected one of: draft, in_progress, shipped, deprecated",
      "check": "field_value_constraint",
      "targetKind": "deliverable",
      "field": "status",
      "constraint": { "kind": "one_of", "values": ["draft", "in_progress", "shipped", "deprecated"] }
    },
    {
      "code": "W095",
      "severity": "warning",
      "messageTemplate": "feature '{id}' has invalid effort '{value}' — expected one of: xs, s, m, l, xl",
      "check": "field_value_constraint",
      "targetKind": "feature",
      "field": "effort",
      "constraint": { "kind": "one_of", "values": ["xs", "s", "m", "l", "xl"] }
    },
    {
      "code": "W041",
      "severity": "warning",
      "messageTemplate": "feature '{id}' has no incoming edges — it may be unreferenced by any journey, milestone, or module",
      "check": "no_incoming_edges",
      "targetKind": "feature"
    },
    {
      "code": "W042",
      "severity": "warning",
      "messageTemplate": "journey '{id}' has no incoming edges — it may be unreferenced by any deliverable",
      "check": "no_incoming_edges",
      "targetKind": "journey"
    },
    {
      "code": "W044",
      "severity": "warning",
      "messageTemplate": "module '{id}' has no incoming edges — it may be unreferenced by any deliverable or milestone",
      "check": "no_incoming_edges",
      "targetKind": "module"
    },
    {
      "code": "I010",
      "severity": "info",
      "messageTemplate": "term '{id}' has no incoming edges — it may be unreferenced",
      "check": "no_incoming_edges",
      "targetKind": "term"
    },
    {
      "code": "I046",
      "severity": "info",
      "messageTemplate": "persona '{id}' has no incoming edges — it may be unreferenced by any journey",
      "check": "no_incoming_edges",
      "targetKind": "persona"
    },
    {
      "code": "I047",
      "severity": "info",
      "messageTemplate": "channel '{id}' has no incoming edges — it may be unreferenced by any journey",
      "check": "no_incoming_edges",
      "targetKind": "channel"
    },
    {
      "code": "E007",
      "severity": "error",
      "messageTemplate": "module dependency cycle detected involving '{id}'",
      "check": "cycle_detection",
      "targetKind": "module",
      "edgeType": "ModuleDependsOn"
    },
    {
      "code": "E015",
      "severity": "error",
      "messageTemplate": "milestone dependency cycle detected involving '{id}'",
      "check": "cycle_detection",
      "targetKind": "milestone",
      "edgeType": "MilestoneDependsOn"
    },
    {
      "code": "E016",
      "severity": "error",
      "messageTemplate": "deliverable dependency cycle detected involving '{id}'",
      "check": "cycle_detection",
      "targetKind": "deliverable",
      "edgeType": "DeliverableDependsOn"
    },
    {
      "code": "W045",
      "severity": "warning",
      "messageTemplate": "feature dependency cycle detected involving '{id}'",
      "check": "cycle_detection",
      "targetKind": "feature",
      "edgeType": "FeatureDependsOn"
    },
    {
      "code": "W092",
      "severity": "warning",
      "messageTemplate": "release dependency cycle detected involving '{id}'",
      "check": "cycle_detection",
      "targetKind": "release",
      "edgeType": "ReleaseDependsOn"
    },
    {
      "code": "W093",
      "severity": "warning",
      "messageTemplate": "release '{id}' has invalid version format — expected semver (e.g., 1.0.0)",
      "check": "field_value_constraint",
      "targetKind": "release",
      "field": "version",
      "constraint": { "kind": "matches", "pattern": "." }
    },
    {
      "code": "W049",
      "severity": "warning",
      "messageTemplate": "milestone '{id}' has no features and no modules — it may be empty",
      "check": "missing_field_when_flag_set",
      "targetKind": "milestone",
      "field": "features"
    }
  ],
  "reservedKeywords": [],
  "peerDependencies": [
    { "name": "@specforge/software", "version": "^1.0" }
  ]
}
