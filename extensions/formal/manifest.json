{
  "name": "@specforge/formal",
  "version": "1.0.0",
  "manifestVersion": 2,
  "wasmPath": "formal.wasm",
  "extShort": "formal",
  "contributes": {
    "entities": true,
    "validators": true
  },
  "peerDependencies": [
    { "name": "@specforge/software", "version": "^1.0" }
  ],
  "entityKinds": [
    {
      "name": "Condition",
      "keyword": "condition",
      "description": "A formal pre/post-condition or invariant for verification",
      "testable": false,
      "supportsVerify": false,
      "semanticToken": "property",
      "lspIcon": "Property",
      "dotShape": "diamond",
      "dotColor": "#1A237E",
      "dotFillcolor": "#E8EAF6",
      "fields": [
        { "name": "expression", "description": "Formal expression defining the condition", "fieldType": "string", "required": true },
        { "name": "kind", "description": "Classification of the condition (e.g. precondition, postcondition, invariant)", "fieldType": "string" },
        { "name": "strength", "description": "Strength level of the condition (e.g. must, should, may)", "fieldType": "string" },
        { "name": "description", "description": "Free-form description of the condition", "fieldType": "string" },
        { "name": "refs", "description": "External references (URLs, documents, issue links)", "fieldType": "string_list" }
      ]
    },
    {
      "name": "Property",
      "keyword": "property",
      "description": "A temporal property assertion (safety, liveness, fairness)",
      "testable": true,
      "supportsVerify": true,
      "allowedVerifyKinds": ["property", "unit"],
      "semanticToken": "property",
      "lspIcon": "Property",
      "dotShape": "hexagon",
      "dotColor": "#0D47A1",
      "dotFillcolor": "#E3F2FD",
      "fields": [
        { "name": "expression", "description": "Formal expression defining the temporal property", "fieldType": "string", "required": true },
        { "name": "property_type", "description": "Category of temporal property (safety, liveness, or fairness)", "fieldType": "string" },
        { "name": "scope", "description": "Applicability scope of this property", "fieldType": "string" },
        { "name": "description", "description": "Free-form description of the property", "fieldType": "string" },
        { "name": "refs", "description": "External references (URLs, documents, issue links)", "fieldType": "string_list" }
      ]
    },
    {
      "name": "Axiom",
      "keyword": "axiom",
      "description": "An assumed-true foundational assertion",
      "testable": false,
      "supportsVerify": false,
      "semanticToken": "constant",
      "lspIcon": "Constant",
      "dotShape": "ellipse",
      "dotColor": "#311B92",
      "dotFillcolor": "#EDE7F6",
      "fields": [
        { "name": "expression", "description": "Formal expression stating the axiom", "fieldType": "string", "required": true },
        { "name": "assumes", "description": "Conditions this axiom assumes as foundational truths", "fieldType": "reference_list", "edge": "AxiomAssumesCondition", "targetKind": "condition" },
        { "name": "justification", "description": "Rationale for why this axiom is assumed true", "fieldType": "string" },
        { "name": "description", "description": "Free-form description of the axiom", "fieldType": "string" },
        { "name": "refs", "description": "External references (URLs, documents, issue links)", "fieldType": "string_list" }
      ]
    },
    {
      "name": "Protocol",
      "keyword": "protocol",
      "description": "A shared synchronization contract between processes",
      "testable": true,
      "supportsVerify": true,
      "allowedVerifyKinds": ["property", "integration"],
      "semanticToken": "interface",
      "lspIcon": "Interface",
      "dotShape": "component",
      "dotColor": "#004D40",
      "dotFillcolor": "#E0F2F1",
      "fields": [
        { "name": "alphabet", "description": "Set of events that this protocol can communicate", "fieldType": "string_list" },
        { "name": "states", "description": "Possible states in the protocol state machine", "fieldType": "string_list" },
        { "name": "transitions", "description": "State transitions triggered by events (from -> event -> to)", "fieldType": "string_list" },
        { "name": "initial_state", "description": "Starting state of the protocol", "fieldType": "string" },
        { "name": "description", "description": "Free-form description of the protocol", "fieldType": "string" },
        { "name": "refs", "description": "External references (URLs, documents, issue links)", "fieldType": "string_list" }
      ]
    },
    {
      "name": "Refinement",
      "keyword": "refinement",
      "description": "A mapping from abstract to concrete specification",
      "testable": false,
      "supportsVerify": true,
      "allowedVerifyKinds": ["property"],
      "semanticToken": "function",
      "lspIcon": "Method",
      "dotShape": "parallelogram",
      "dotColor": "#1B5E20",
      "dotFillcolor": "#E8F5E9",
      "fields": [
        { "name": "abstract_entity", "description": "Reference to the abstract behavior being refined", "fieldType": "reference", "edge": "RefinementRefinesAbstract", "targetKind": "behavior" },
        { "name": "concrete_entity", "description": "Reference to the concrete behavior that implements the refinement", "fieldType": "reference", "edge": "RefinementRefinesConcrete", "targetKind": "behavior" },
        { "name": "condition_deltas", "description": "Changes to conditions introduced or relaxed by this refinement", "fieldType": "string_list" },
        { "name": "chains_to", "description": "Next refinement in the refinement chain", "fieldType": "reference", "edge": "RefinementChainsToRefinement", "targetKind": "refinement" },
        { "name": "description", "description": "Free-form description of the refinement mapping", "fieldType": "string" },
        { "name": "refs", "description": "External references (URLs, documents, issue links)", "fieldType": "string_list" }
      ]
    },
    {
      "name": "Process",
      "keyword": "process",
      "description": "A CSP-style communicating process with states and transitions",
      "testable": true,
      "supportsVerify": true,
      "allowedVerifyKinds": ["property", "integration"],
      "semanticToken": "function",
      "lspIcon": "Method",
      "dotShape": "ellipse",
      "dotColor": "#006064",
      "dotFillcolor": "#E0F7FA",
      "fields": [
        { "name": "alphabet", "description": "Set of events that this process can communicate", "fieldType": "string_list" },
        { "name": "states", "description": "Possible states in the process state machine", "fieldType": "string_list" },
        { "name": "initial_state", "description": "Starting state of the process", "fieldType": "string" },
        { "name": "composition", "description": "Composition operator and sub-processes (e.g. parallel, sequential, choice)", "fieldType": "string" },
        { "name": "sub_processes", "description": "Sub-processes composed by this process", "fieldType": "reference_list", "edge": "ProcessComposesProcess", "targetKind": "process" },
        { "name": "description", "description": "Free-form description of the process", "fieldType": "string" },
        { "name": "refs", "description": "External references (URLs, documents, issue links)", "fieldType": "string_list" }
      ]
    }
  ],
  "edgeTypes": [
    {
      "label": "BehaviorRequiresCondition",
      "description": "Behavior requires a condition as precondition",
      "sourceKind": "behavior",
      "targetKind": "condition",
      "edgeStyle": "solid",
      "edgeColor": "#1A237E"
    },
    {
      "label": "BehaviorEnsuresCondition",
      "description": "Behavior ensures a condition as postcondition",
      "sourceKind": "behavior",
      "targetKind": "condition",
      "edgeStyle": "solid",
      "edgeColor": "#1A237E"
    },
    {
      "label": "BehaviorMaintainsCondition",
      "description": "Behavior maintains a condition as frame invariant throughout execution",
      "sourceKind": "behavior",
      "targetKind": "condition",
      "edgeStyle": "dashed",
      "edgeColor": "#1A237E"
    },
    {
      "label": "AxiomAssumesCondition",
      "description": "Axiom assumes a condition as foundational truth",
      "sourceKind": "axiom",
      "targetKind": "condition",
      "edgeStyle": "dotted",
      "edgeColor": "#311B92"
    },
    {
      "label": "BehaviorSatisfiesProperty",
      "description": "Behavior satisfies a temporal property",
      "sourceKind": "behavior",
      "targetKind": "property",
      "edgeStyle": "solid",
      "edgeColor": "#0D47A1"
    },
    {
      "label": "EventFollowsProtocol",
      "description": "Event follows a synchronization protocol",
      "sourceKind": "event",
      "targetKind": "protocol",
      "edgeStyle": "solid",
      "edgeColor": "#004D40"
    },
    {
      "label": "PropertyDependsOnCondition",
      "description": "Property depends on a condition",
      "sourceKind": "property",
      "targetKind": "condition",
      "edgeStyle": "dashed",
      "edgeColor": "#0D47A1"
    },
    {
      "label": "RefinementRefinesAbstract",
      "description": "Refinement maps from this abstract behavior",
      "sourceKind": "refinement",
      "targetKind": "behavior",
      "edgeStyle": "dashed",
      "edgeColor": "#1B5E20"
    },
    {
      "label": "RefinementRefinesConcrete",
      "description": "Refinement maps to this concrete behavior",
      "sourceKind": "refinement",
      "targetKind": "behavior",
      "edgeStyle": "solid",
      "edgeColor": "#1B5E20"
    },
    {
      "label": "RefinementChainsToRefinement",
      "description": "Chain of refinements",
      "sourceKind": "refinement",
      "targetKind": "refinement",
      "edgeStyle": "dashed",
      "edgeColor": "#1B5E20"
    },
    {
      "label": "EventParticipatesInProcess",
      "description": "Event participates in a process",
      "sourceKind": "event",
      "targetKind": "process",
      "edgeStyle": "solid",
      "edgeColor": "#006064"
    },
    {
      "label": "ProcessComposesProcess",
      "description": "Process composes sub-processes",
      "sourceKind": "process",
      "targetKind": "process",
      "edgeStyle": "solid",
      "edgeColor": "#006064"
    }
  ],
  "entityEnhancements": [
    {
      "targetKind": "behavior",
      "sourceExtension": "@specforge/formal",
      "fields": [
        { "name": "requires", "description": "Preconditions that must hold before execution", "fieldType": "reference_list", "edge": "BehaviorRequiresCondition", "targetKind": "condition" },
        { "name": "ensures", "description": "Postconditions guaranteed after successful execution", "fieldType": "reference_list", "edge": "BehaviorEnsuresCondition", "targetKind": "condition" },
        { "name": "maintains", "description": "Conditions preserved throughout execution", "fieldType": "reference_list", "edge": "BehaviorMaintainsCondition", "targetKind": "condition" },
        { "name": "satisfies", "description": "Temporal properties this behavior satisfies", "fieldType": "reference_list", "edge": "BehaviorSatisfiesProperty", "targetKind": "property" },
        { "name": "sync", "description": "Synchronization constraints for execution", "fieldType": "string_list" }
      ]
    },
    {
      "targetKind": "event",
      "sourceExtension": "@specforge/formal",
      "fields": [
        { "name": "follows_protocol", "description": "Synchronization protocol this event follows", "fieldType": "reference_list", "edge": "EventFollowsProtocol", "targetKind": "protocol" },
        { "name": "participates_in", "description": "Processes this event participates in", "fieldType": "reference_list", "edge": "EventParticipatesInProcess", "targetKind": "process" },
        { "name": "sync", "description": "Synchronization constraints for event processing", "fieldType": "string_list" }
      ]
    }
  ],
  "validationRules": [
    {
      "code": "W058",
      "severity": "warning",
      "messageTemplate": "condition '{id}' has invalid kind '{value}' — expected one of: precondition, postcondition, invariant",
      "check": "field_value_constraint",
      "targetKind": "condition",
      "field": "kind",
      "constraint": { "kind": "one_of", "values": ["precondition", "postcondition", "invariant"] }
    },
    {
      "code": "W059",
      "severity": "warning",
      "messageTemplate": "property '{id}' has invalid property_type '{value}' — expected one of: safety, liveness, fairness",
      "check": "field_value_constraint",
      "targetKind": "property",
      "field": "property_type",
      "constraint": { "kind": "one_of", "values": ["safety", "liveness", "fairness"] }
    }
  ],
  "reservedKeywords": []
}
