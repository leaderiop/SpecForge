// Generated by specforge model
// Model version: 1.0.0

// ── @specforge/software ──

TableGroup software {
  behavior
  event
}

Table behavior {
  id string [pk]
  contract string [not null, note: 'The contract']
  features string [ref: > feature.id, note: 'BehaviorImplementsFeature -> feature']
}

Table event {
  id string [pk]
}

// ── @specforge/product ──

TableGroup product {
  feature
  journey
}

Table feature {
  id string [pk]
}

Table journey {
  id string [pk]
}

// ── Relationships ──

Ref BehaviorImplementsFeature: behavior.features > feature.id
Ref Triggers: behavior.id > event.id
Ref JourneyExercisesFeature: journey.id > feature.id
