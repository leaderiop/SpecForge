    "scrollbarSlider.hoverBackground": "#45475a80",
    "scrollbarSlider.activeBackground": "#45475aaa",
    "minimap.background": "#1e1e2e",
    "minimapGutter.addedBackground": "#a6e3a1",
    "minimapGutter.modifiedBackground": "#f9e2af",
    "minimapGutter.deletedBackground": "#f38ba8",
    "gitDecoration.addedResourceForeground": "#a6e3a1",
    "gitDecoration.modifiedResourceForeground": "#f9e2af",
    "gitDecoration.deletedResourceForeground": "#f38ba8",
    "gitDecoration.untrackedResourceForeground": "#a6e3a1",
    "gitDecoration.conflictingResourceForeground": "#fab387",
    "focusBorder": "#89b4fa80",
    "selection.background": "#45475a80",
    "foreground": "#cdd6f4",
    "descriptionForeground": "#a6adc8",
    "errorForeground": "#f38ba8",
    "widget.shadow": "#00000040",
    "textLink.foreground": "#89b4fa",
    "textLink.activeForeground": "#74c7ec",
    "breadcrumb.foreground": "#6c7086",
    "breadcrumb.focusForeground": "#cdd6f4",
    "breadcrumbPicker.background": "#181825",
    "peekView.border": "#89b4fa",
    "peekViewEditor.background": "#181825",
    "peekViewResult.background": "#181825",
    "peekViewTitle.background": "#181825",
    "peekViewTitleLabel.foreground": "#cdd6f4",
    "peekViewTitleDescription.foreground": "#a6adc8"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": "comment, comment.line.double-slash.specforge",
      "settings": {
        "foreground": "#6c7086",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": "string, string.quoted.double.specforge, string.quoted.triple.specforge, string.quoted.double.title.specforge",
      "settings": {
        "foreground": "#a6e3a1"
      }
    },
    {
      "name": "String escape",
      "scope": "constant.character.escape.specforge",
      "settings": {
        "foreground": "#f2cdcd"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric, constant.numeric.specforge, constant.numeric.date.specforge",
      "settings": {
        "foreground": "#fab387"
      }
    },
    {
      "name": "Boolean",
      "scope": "constant.language.boolean.specforge",
      "settings": {
        "foreground": "#f38ba8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Structural keywords (spec, use, from, as, pub, define, ref)",
      "scope": "keyword.control.specforge, keyword.control.import.specforge, keyword.control.from.specforge, keyword.control.as.specforge, keyword.control.pub.specforge, keyword.control.spec.specforge, keyword.control.define.specforge, keyword.control.ref.specforge",
      "settings": {
        "foreground": "#89b4fa",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Verify keyword",
      "scope": "keyword.control.verify.specforge",
      "settings": {
        "foreground": "#f38ba8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Entity kind keyword (behavior, feature, type, etc.)",
      "scope": "keyword.other.entity-kind.specforge",
      "settings": {
        "foreground": "#89b4fa",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Entity name / ID at declaration",
      "scope": "entity.name.function.specforge, entity.name.type.define.specforge",
      "settings": {
        "foreground": "#f9e2af",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Union type name at declaration",
      "scope": "entity.name.type.union.specforge",
      "settings": {
        "foreground": "#f9e2af",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Scheme ref ID (gh.issue:42)",
      "scope": "constant.other.scheme-ref-id.specforge",
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "Field names",
      "scope": "variable.other.property.specforge",
      "settings": {
        "foreground": "#89dceb"
      }
    },
    {
      "name": "Reference IDs in lists",
      "scope": "variable.other.reference.specforge",
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "name": "Scheme ref in list",
      "scope": "variable.other.scheme-ref.specforge",
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "name": "Verify kind (unit, integration, property, etc.)",
      "scope": "variable.other.enummember.specforge",
      "settings": {
        "foreground": "#f5c2e7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Annotation (@optional, @deprecated)",
      "scope": "entity.other.attribute-name.specforge",
      "settings": {
        "foreground": "#f9e2af",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Import binding names",
      "scope": "entity.name.function.import.specforge",
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "Namespace alias",
      "scope": "entity.name.namespace.specforge",
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "Wildcard operator (*)",
      "scope": "keyword.operator.wildcard.specforge",
      "settings": {
        "foreground": "#89b4fa"
      }
    },
    {
      "name": "Union operator (|) and assignment (=)",
      "scope": "keyword.operator.union.specforge, keyword.operator.assignment.specforge",
      "settings": {
        "foreground": "#89dceb"
      }
    },
    {
      "name": "Union variant types",
      "scope": "support.type.variant.specforge",
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "name": "Array type identifier (e.g., EntityId in EntityId[])",
      "scope": "support.type.specforge",
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "name": "Array type brackets []",
      "scope": "punctuation.definition.array.specforge",
      "settings": {
        "foreground": "#a6adc8"
      }
    },
    {
      "name": "Field value (plain identifier)",
      "scope": "variable.other.value.specforge",
      "settings": {
        "foreground": "#cdd6f4"
      }
    },
    {
      "name": "Punctuation (brackets, braces, commas)",
      "scope": "punctuation.definition.list.begin.specforge, punctuation.definition.list.end.specforge, punctuation.separator.comma.specforge, punctuation.definition.block.begin.specforge, punctuation.definition.block.end.specforge",
      "settings": {
        "foreground": "#a6adc8"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "keyword": {
      "foreground": "#89b4fa",
      "bold": true
    },
    "type": {
      "foreground": "#89b4fa",
      "bold": true
    },
    "function": {
      "foreground": "#f9e2af",
      "bold": true
    },
    "function.declaration": {
      "foreground": "#f9e2af",
      "bold": true
    },
    "variable": {
      "foreground": "#cba6f7"
    },
    "variable.reference": {
      "foreground": "#cba6f7"
    },
    "property": {
      "foreground": "#89dceb"
    },
    "string": {
      "foreground": "#a6e3a1"
    },
    "comment": {
      "foreground": "#6c7086",
      "italic": true
    },
    "number": {
      "foreground": "#fab387"
    },
    "enumMember": {
      "foreground": "#f5c2e7",
      "italic": true
    }
  }
}
